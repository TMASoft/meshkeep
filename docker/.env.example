# Copy to a `.env` file next to your compose file (e.g. ./compose.yml) and edit.
# Docker Compose auto-loads `.env` and substitutes ${VAR} references in the
# compose file. NEVER commit a real `.env` — it is gitignored for this reason.
#
# For stronger secret handling (files, not env), use Docker/Swarm secrets or
# your orchestrator's secret store; see docs/operations.md.

# Require a login for the web UI + REST API. Leave empty/unset for an open
# instance (trusted LAN only). Mint scoped API tokens in Radio -> API access.
MESHKEEP_UI_PASSWORD=change-me
