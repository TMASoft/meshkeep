{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "jsx": "preserve",
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts"]
}
