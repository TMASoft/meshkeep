{
  "name": "@meshkeep/server",
  "version": "0.1.2-beta",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:mock": "MESHKEEP_CONNECTION=tcp MESHKEEP_TCP_HOST=127.0.0.1 MESHKEEP_TCP_PORT=5100 tsx watch src/index.ts",
    "mock-radio": "tsx src/radio/mock/run-mock.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@liamcottle/meshcore.js": "^1.13.0",
    "@meshkeep/shared": "*",
    "better-sqlite3": "^12.0.0",
    "express": "^4.21.0",
    "node-ble": "^1.13.0",
    "serialport": "^13.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
